# Polymarket BTC 5-Min Trading Bot Configuration

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Log format: text (colored terminal output) or json (machine-readable)
LOG_FORMAT=text

# Gamma API (market discovery)
GAMMA_API_URL=https://gamma-api.polymarket.com

# CLOB WebSocket (orderbook, prices, trades)
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# RTDS WebSocket (live BTC/USD price)
RTDS_WS_URL=wss://ws-live-data.polymarket.com

# Market filter
MARKET_SLUG_PREFIX=btc-updown-5m

# Data directory (SQLite trade database)
DATA_DIR=./data

# --- SNS alerts (optional) ---
# Create topic:     aws sns create-topic --name go-tec-alerts
# Subscribe email:  aws sns subscribe --topic-arn <arn> --protocol email --notification-endpoint your@gmail.com
# (confirm the subscription email that AWS sends)
SNS_TOPIC_ARN=

# --- HTTP Status API (optional) ---
# Set a port to enable the status API (e.g., 8080)
# Endpoints: /health, /status, /trades, /stats
# Protected by EC2 security group (restrict to your IP)
API_PORT=8080

# --- Phase 5+ (trading, not needed for Phase 1) ---
# POLYMARKET_PK=your_private_key_here
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
