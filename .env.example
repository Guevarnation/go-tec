# Polymarket BTC 5-Min Trading Bot Configuration

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Log format: text (colored terminal output) or json (machine-readable)
LOG_FORMAT=text

# Gamma API (market discovery)
GAMMA_API_URL=https://gamma-api.polymarket.com

# CLOB WebSocket (orderbook, prices, trades)
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# RTDS WebSocket (live BTC/USD price)
RTDS_WS_URL=wss://ws-live-data.polymarket.com

# Market filter
MARKET_SLUG_PREFIX=btc-updown-5m

# Data directory (SQLite trade database)
DATA_DIR=./data

# --- Phase 5+ (trading, not needed for Phase 1) ---
# POLYMARKET_PK=your_private_key_here
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
